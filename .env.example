# ReddID Next — Environment Variables
# Copy this file to .env.local for local overrides.
# Variables marked REQUIRED must be set on Railway before deploying.

# ── Database ───────────────────────────────────────────────────────────────────

# REQUIRED on Railway: absolute path on your persistent volume.
# Default (local dev): <process.cwd()>/data/db.json
# REDDID_DB_PATH=/app/data/db.json

# DataStore backend engine. Leave unset to use the JSON file store.
# 'json'   — JsonFileDataStore (default)
# 'sqlite' — SqliteDataStore (Sprint 4 S4-01 — not yet available)
# REDDID_DB_ENGINE=json

# ── Admin ──────────────────────────────────────────────────────────────────────

# REQUIRED to use /admin/reports triage queue. No default.
# Generate: openssl rand -hex 32
# ADMIN_SECRET=your-32-char-hex-secret-here

# ── Block explorer ─────────────────────────────────────────────────────────────

# ReddCoin Blockbook v2 API base URL (no trailing slash). Server-side only.
# Default: https://blockbook.reddcoin.com
# REDDID_BLOCKBOOK_URL=https://blockbook.reddcoin.com

# Client-side Blockbook URL (NEXT_PUBLIC_ prefix makes it browser-accessible).
# Default: https://blockbook.reddcoin.com
# NEXT_PUBLIC_REDDID_BLOCKBOOK_URL=https://blockbook.reddcoin.com

# ── Public base URL ────────────────────────────────────────────────────────────

# REQUIRED on Railway: canonical public origin (no trailing slash).
# Used in sitemap, OG tags, HTTPS redirect in next.config.ts.
# Default: https://redd.love
# NEXT_PUBLIC_REDDID_BASE_URL=https://redd.love

# ── Node environment ───────────────────────────────────────────────────────────
# Set by Next.js automatically; no need to set manually in most cases.
# NODE_ENV=production
