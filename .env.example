# ReddID Next — Environment Variables
# Copy this file to .env.local for local overrides.
# All variables are optional; defaults are shown as comments.

# ── Database ───────────────────────────────────────────────────────────────────
# Absolute path to the JSON database file.
# On Railway, set this to a path on your persistent volume, e.g. /app/data/db.json
# Default: <process.cwd()>/data/db.json
# REDDID_DB_PATH=/app/data/db.json

# ── Block explorer ─────────────────────────────────────────────────────────────
# ReddCoin Blockbook v2 API base URL (no trailing slash).
# Used server-side for recent transaction lists and balance checks.
# Default: https://blockbook.reddcoin.com
# REDDID_BLOCKBOOK_URL=https://blockbook.reddcoin.com

# Client-side Blockbook URL (must use NEXT_PUBLIC_ prefix to reach the browser).
# Set this when you want the LiveBalance widget to point at a different node.
# Default: https://blockbook.reddcoin.com
# NEXT_PUBLIC_REDDID_BLOCKBOOK_URL=https://blockbook.reddcoin.com

# ── Public base URL ────────────────────────────────────────────────────────────
# Canonical public origin of this deployment — used in sitemap, OG tags, etc.
# Override for staging or self-hosted instances.
# Default: https://redd.love
# NEXT_PUBLIC_REDDID_BASE_URL=https://redd.love

# ── Node environment ───────────────────────────────────────────────────────────
# Set by Next.js automatically; no need to set manually in most cases.
# NODE_ENV=production
